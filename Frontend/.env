# Use relative path — Vite dev proxy forwards /api/* to the Kali VM backend.
# This eliminates all CORS issues since the browser talks to its own origin.
VITE_API_BASE_URL=/api/v1
# Direct backend (cross-origin, requires CORS):
# VITE_API_BASE_URL=http://192.168.56.102:8000/api/v1
# VITE_API_BASE_URL=https://refusal-quill-ashen.ngrok-free.dev/api/v1