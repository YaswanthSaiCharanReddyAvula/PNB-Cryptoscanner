# ── QuantumShield — Environment Variables ─────────────────────────
#
# Shared folder (Windows host + Kali VM): copy this file to `.env` on each machine.
# CORS_ORIGINS must be comma-separated (not JSON). See Backend/README.md.

# ── Application ──────────────────────────────────────────────────
APP_NAME=QuantumShield
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── MongoDB (existing scanner pipeline) ──────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=quantumshield

# ── PostgreSQL (Assessment System API) ───────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quantumshield

# ── JWT ──────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret for production!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ─────────────────────────────────────────────────────────
# "*" = allow any origin (recommended for hackathon / dev). With "*", credentials mode is off.
# For stricter setups, use comma-separated origins (then allow_credentials can be true):
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CORS_ORIGINS=*

# ── Portfolio / batch scans (Phase 2) ────────────────────────────
# MAX_BATCH_DOMAINS=25
# MAX_CONCURRENT_SCANS=3

# ── TLS / testssl.sh ─────────────────────────────────────────────
# Per host:port probe cap (testssl is skipped on DB/cache ports 3306, 5432, …).
# TESTSSL_TIMEOUT=90
