# ── QuantumShield — Environment Variables ─────────────────────────
#
# Shared folder (Windows host + Kali VM): copy this file to `.env` on each machine.
# CORS_ORIGINS must be comma-separated (not JSON). See Backend/README.md.

# ── Application ──────────────────────────────────────────────────
APP_NAME=QuantumShield
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── MongoDB (existing scanner pipeline) ──────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=quantumshield

# ── PostgreSQL (Assessment System API) ───────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quantumshield

# ── JWT ──────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret for production!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ─────────────────────────────────────────────────────────
# "*" = allow any origin (recommended for hackathon / dev). With "*", credentials mode is off.
# For stricter setups, use comma-separated origins (then allow_credentials can be true):
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
CORS_ORIGINS=*

# ── Portfolio / batch scans (Phase 2) ────────────────────────────
# MAX_BATCH_DOMAINS=25
# MAX_CONCURRENT_SCANS=3

# ── Scan retention & in-place rescan ─────────────────────────────
# Terminal scans (completed/failed) older than SCAN_RETENTION_DAYS are deleted.
# Rescan for the same domain within SCAN_REUSE_WINDOW_DAYS reuses the same Mongo document + scan_id.
# SCAN_RETENTION_DAYS=30
# SCAN_REUSE_WINDOW_DAYS=30
# SCAN_PURGE_INTERVAL_SECONDS=3600

# ── TLS / testssl.sh ─────────────────────────────────────────────
# Per host:port probe cap (testssl is skipped on DB/cache ports 3306, 5432, …).
# TESTSSL_TIMEOUT=90

# ── Asset classification (HTTP probes on web hosts; capped per scan) ──
# CLASSIFICATION_PROBE_TIMEOUT=8
# CLASSIFICATION_MAX_HTTP_PROBES=40

# ── Optional Nuclei active scan (Linux VM / server; keep false on Windows dev) ──
# ENABLE_NUCLEI=false
# NUCLEI_BINARY=nuclei
# NUCLEI_MAX_HOSTS=15
# NUCLEI_TAGS=tls,misconfig,technologies
# NUCLEI_TEMPLATE_TIMEOUT_SECONDS=10

# ── LM Studio / OpenAI-compatible chat (local) ─────────────────
# Backend must reach this host (same machine or LAN). You may set either:
#   LLM_BASE_URL=http://192.168.56.1:1234
# or the full path:
#   LLM_BASE_URL=http://192.168.56.1:1234/v1/chat/completions
# In LM Studio: enable Server, load a model, note the model id for LLM_MODEL.
# LLM_MODEL=gemma-3-4b-it
# LLM_TIMEOUT_SECONDS=120
# LLM_API_KEY=
# Leave false so local LM Studio is not sent through HTTP_PROXY (fixes "All connection attempts failed").
# LLM_TRUST_ENV=false

# ── SMTP (scheduled report email) ───────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true

# ── Scheduled JSON reports ────────────────────────────────────
# REPORT_SCHEDULER_POLL_SECONDS=30
# REPORT_MAX_ATTACHMENT_MB=10
# GENERATED_REPORTS_DIR=generated_reports
