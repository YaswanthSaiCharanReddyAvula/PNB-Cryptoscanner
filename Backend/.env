# ── QuantumShield — Environment Variables ─────────────────────────

# ── Application ──────────────────────────────────────────────────
APP_NAME=QuantumShield
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── MongoDB (existing scanner pipeline) ──────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=quantumshield

# ── PostgreSQL (REMOVED) ─────────────────────────────────────────
# POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quantumshield

# ── JWT ──────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret for production!
SECRET_KEY=long_random_secret_key_for_jwt
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS ─────────────────────────────────────────────────────────
# "*" = allow any browser origin (allow_credentials=false). Or comma-separated explicit URLs.
CORS_ORIGINS=*

# ── LM Studio / OpenAI-compatible (Copilot, roadmap AI) ─────────
# Backend must reach this host. Base URL is OK — the app appends /v1/chat/completions.
# In LM Studio: Local Server ON, note port; load a model; set LLM_MODEL to that model id.
LLM_BASE_URL=http://192.168.56.1:1234
LLM_MODEL=gemma-3-4b-it
LLM_TIMEOUT_SECONDS=120
LLM_API_KEY=
# false = do not use HTTP_PROXY for LM calls (fixes many "connection failed" cases)
LLM_TRUST_ENV=false

# ── SMTP (scheduled report email; optional) ─────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=true

# ── Scheduled JSON reports (optional) ───────────────────────────
# REPORT_SCHEDULER_POLL_SECONDS=30
# REPORT_MAX_ATTACHMENT_MB=10
# GENERATED_REPORTS_DIR=generated_reports
