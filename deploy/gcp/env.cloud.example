# Copy values into Secret Manager or an env file on the GCE VM (never commit real secrets).

APP_NAME=QuantumShield
DEBUG=false
LOG_LEVEL=INFO

# MongoDB Atlas (GCP region) — SRV or standard URI
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/quantumshield?retryWrites=true&w=majority
MONGO_DB_NAME=quantumshield

# Cloud SQL — use Unix socket on Cloud Run, or host:5432 on GCE with authorized network
POSTGRES_URL=postgresql+asyncpg://qs_app:PASSWORD@10.x.x.x:5432/quantumshield

SECRET_KEY=use_python_secrets_token_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Exact HTTPS origins of Firebase / GCS static site (comma-separated, no spaces)
CORS_ORIGINS=https://your-project.web.app,https://api.yourdomain.com

# LLM — Option A: Tailscale IP of Windows LM Studio; Option B: Vertex/OpenAI-compatible URL
LLM_BASE_URL=http://100.x.x.x:1234/v1/chat/completions
LLM_MODEL=gemma-3-4b-it
LLM_TIMEOUT_SECONDS=120
LLM_API_KEY=
LLM_TRUST_ENV=false

# Optional: Nuclei on Linux image only
# ENABLE_NUCLEI=true
